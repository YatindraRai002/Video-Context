# Application
DEBUG=false
APP_NAME=ClipCompass
API_PREFIX=/api/v1

# Database
DATABASE_URL=sqlite:///./clipcompass.db

# Qdrant Vector Database
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_TRANSCRIPTS=transcript_embeddings
QDRANT_COLLECTION_FRAMES=frame_embeddings

# Redis/Celery
REDIS_URL=redis://redis:6379/0

# AI Models
WHISPER_MODEL=small
CLIP_MODEL=ViT-B/32
TEXT_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Processing Settings
FRAME_EXTRACTION_FPS=1.0
MAX_VIDEO_DURATION_MINUTES=60
TRANSCRIPT_CHUNK_SIZE=10

# Frontend (for development)
NEXT_PUBLIC_API_URL=http://localhost:8000
